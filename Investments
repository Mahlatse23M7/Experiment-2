function WhatIfPanel() {
  const [extra, setExtra] = useState(5000);
  const retirement = GOALS.find(g => g.name === "Retirement");
  const r = retirement.expectedReturn / 12;
  function monthsToTarget(monthlyAdd) {
    let bal = retirement.current, months = 0;
    while (bal < retirement.target && months < 600) { bal = bal * (1 + r) + retirement.monthly + monthlyAdd; months++; }
    return months;
  }
  const baseMonths = monthsToTarget(0);
  const newMonths = monthsToTarget(extra);
  const monthsSaved = baseMonths - newMonths;
  return (
    <Panel className="p-5">
      <p style={{ fontSize: 13.5, color: C.textMuted, marginBottom: 16 }}>
        Simulate investing an extra amount per month toward your <strong style={{ color: C.text }}>Retirement</strong> goal.
      </p>
      <div className="flex items-center gap-4 flex-wrap mb-6">
        <input
          type="range" min={0} max={20000} step={500} value={extra}
          onChange={e => setExtra(Number(e.target.value))}
          style={{ flex: 1, minWidth: 200, accentColor: C.gold }}
        />
        <div className="tnum" style={{ fontSize: 18, color: C.gold, minWidth: 120 }}>{fmtZAR(extra)}/mo</div>
      </div>
      <div className="grid grid-cols-3 gap-4">
        <div>
          <div className="mono" style={{ fontSize: 10.5, color: C.textFaint }}>CURRENT PACE</div>
          <div className="tnum" style={{ fontSize: 16 }}>{(baseMonths / 12).toFixed(1)} yrs</div>
        </div>
        <div>
          <div className="mono" style={{ fontSize: 10.5, color: C.textFaint }}>WITH EXTRA</div>
          <div className="tnum" style={{ fontSize: 16, color: C.gain }}>{(newMonths / 12).toFixed(1)} yrs</div>
        </div>
        <div>
          <div className="mono" style={{ fontSize: 10.5, color: C.textFaint }}>TIME SAVED</div>
          <div className="tnum" style={{ fontSize: 16, color: C.gold }}>{(monthsSaved / 12).toFixed(1)} yrs</div>
        </div>
      </div>
    </Panel>
  );
}

