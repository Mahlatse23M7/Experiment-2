                                }}
                              />
                              <span className="mono" style={{ fontSize: 10, color: C.textFaint }}>{m.unit}</span>
                            </div>
                          </td>
                        );
                      })}
                    </tr>
                  ))}
                </React.Fragment>
              ))}
            </tbody>
          </table>
        </div>
      </Panel>
    </div>
  );
}

function Fundamental({ label, value, highlight }) {
  return (
    <div>
      <div className="mono" style={{ fontSize: 10.5, color: C.textFaint, letterSpacing: "0.04em" }}>{label.toUpperCase()}</div>
      <div className="tnum" style={{ fontSize: 16, color: highlight ? C.gold : C.text, marginTop: 2 }}>{value}</div>
    </div>
  );
}

