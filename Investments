function genReturns(mean, vol, seedOffset) {
  const r = [];
  let s = 1000 + seedOffset;
  const rnd = mulberry32(s);
  for (let i = 0; i < MONTHS; i++) {
    const z = (rnd() + rnd() + rnd() - 1.5) / 1.5; // approx normal-ish
    r.push(mean + vol * z);
  }
  return r;
}
