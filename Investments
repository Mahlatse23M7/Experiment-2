function GainText({ value, digits = 1, pct = true, showIcon = true, className = "" }) {
  const positive = value >= 0;
  return (
    <span
      className={`inline-flex items-center gap-1 ${className}`}
      style={{ color: positive ? C.gain : C.loss, fontFamily: "'IBM Plex Mono', monospace" }}
    >
      {showIcon && (positive ? <ArrowUpRight size={13} /> : <ArrowDownRight size={13} />)}
      {pct ? fmtPct(value, digits) : fmtZAR(value)}
    </span>
  );
}

