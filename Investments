const SCREENER_CATEGORIES = [...new Set(SCREENER_METRICS.map(m => m.cat))];

function passesTest(m, v) {
  if (v === "" || v === null || v === undefined || Number.isNaN(v)) return null;
  if (m.cmp === ">") return v > m.val;
  if (m.cmp === "<") return v < m.val;
  if (m.cmp === ">=") return v >= m.val;
  return null;
}

function scoreCandidate(metrics) {
  let pass = 0, total = 0;
  SCREENER_METRICS.forEach(m => {
    const r = passesTest(m, metrics[m.key]);
    if (r !== null) { total++; if (r) pass++; }
  });
  return { pass, total, pct: total ? pass / total : 0 };
}

function verdict(pct) {
  if (pct >= 0.85) return { label: "Exceptional Quality", color: C.gain };
  if (pct >= 0.7) return { label: "High Quality", color: C.gold };
  if (pct >= 0.5) return { label: "Watch List", color: C.blue };
  return { label: "Below Threshold", color: C.loss };
}

/* seed a plausible starting value per metric so the table isn't empty */
function seedMetrics(offset, flavor) {
  const rnd = mulberry32(500 + offset);
  const out = {};
  SCREENER_METRICS.forEach(m => {
    const spread = 0.55 + rnd() * 1.1; // sits above/below threshold organically
    let v = m.val * spread + (m.cmp === ">" && m.val === 0 ? rnd() * 12 - 3 : 0);
    v = Math.round(v * 10) / 10;
    out[m.key] = v;
  });
  return { ...out, ...flavor };
}

